    {
      "name": "Ejercicio 1 - Busqueda de vuelos",
      "item": [
        {
          "name": "1) GET /flights - sin filtros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/flights",
              "host": ["{{baseUrl}}"],
              "path": ["flights"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Respuesta trae source y flights', function () {",
                  "  pm.expect(data).to.have.property('source');",
                  "  pm.expect(data).to.have.property('flights');",
                  "  pm.expect(data.flights).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
