    {
      "name": "Ejercicio 3 - Reservaciones",
      "item": [
        {
          "name": "1) GET /flights/1/seats - obtener asiento disponible",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/flights/1/seats",
              "host": ["{{baseUrl}}"],
              "path": ["flights", "1", "seats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "const availableSeat = data.seats.find((seat) => seat.status === 'available');",
                  "pm.test('Hay al menos un asiento disponible', function () {",
                  "  pm.expect(availableSeat).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.collectionVariables.set('reserveSeatId', availableSeat.id);",
                  "pm.collectionVariables.set('reserveSeatNumber', availableSeat.seatNumber);",
                  "pm.test('Se guardaron las variables reserveSeatId y reserveSeatNumber', function () {",
                  "  pm.expect(pm.collectionVariables.get('reserveSeatId')).to.not.be.undefined;",
                  "  pm.expect(pm.collectionVariables.get('reserveSeatNumber')).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2) POST /flights/1/reservations - reserva exitosa",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seatId\": {{reserveSeatId}},\n  \"passengerName\": \"Carlos López\",\n  \"passengerEmail\": \"carlos@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/flights/1/reservations",
              "host": ["{{baseUrl}}"],
              "path": ["flights", "1", "reservations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Respuesta contiene los campos esperados', function () {",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('flightId');",
                  "  pm.expect(data).to.have.property('seatId');",
                  "  pm.expect(data).to.have.property('passengerName');",
                  "  pm.expect(data).to.have.property('passengerEmail');",
                  "  pm.expect(data).to.have.property('status');",
                  "  pm.expect(data).to.have.property('confirmationCode');",
                  "  pm.expect(data).to.have.property('createdAt');",
                  "});",
                  "",
                  "pm.test('flightId es 1', function () {",
                  "  pm.expect(data.flightId).to.eql(1);",
                  "});",
                  "",
                  "pm.test('seatId coincide con reserveSeatId', function () {",
                  "  pm.expect(String(data.seatId)).to.eql(pm.collectionVariables.get('reserveSeatId'));",
                  "});",
                  "",
                  "pm.test('status es pending', function () {",
                  "  pm.expect(data.status).to.eql('pending');",
                  "});",
                  "",
                  "pm.test('confirmationCode es null', function () {",
                  "  pm.expect(data.confirmationCode).to.be.null;",
                  "});",
                  "",
                  "pm.collectionVariables.set('reservationId', data.id);"
                ]
              }
            }
          ]
        },
