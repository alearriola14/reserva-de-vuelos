    {
      "name": "Ejercicio 2 - Mapa de asientos",
      "item": [
        {
          "name": "1) GET /flights/1/seats (primera consulta)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/flights/1/seats",
              "host": ["{{baseUrl}}"],
              "path": ["flights", "1", "seats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Respuesta trae source y seats', function () {",
                  "  pm.expect(data).to.have.property('source');",
                  "  pm.expect(data).to.have.property('seats');",
                  "  pm.expect(data.seats).to.be.an('array').that.is.not.empty;",
                  "});",
                  "",
                  "const availableSeat = data.seats.find((seat) => seat.status === 'available');",
                  "pm.test('Hay al menos un asiento disponible para reservar', function () {",
                  "  pm.expect(availableSeat).to.not.be.undefined;",
                  "});",
                  "pm.collectionVariables.set('seatId', availableSeat.id);"
                ]
              }
            }
          ]
        },
