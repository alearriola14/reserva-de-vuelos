              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"held\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/flights/1/seats/{{seatId}}",
              "host": ["{{baseUrl}}"],
