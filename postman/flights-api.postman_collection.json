            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('El asiento queda en estado held', function () {",
                  "  pm.expect(data.status).to.eql('held');",
                  "  pm.expect(String(data.id)).to.eql(pm.collectionVariables.get('seatId'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4) GET /flights/1/seats (cache invalidada tras el PATCH)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/flights/1/seats",
              "host": ["{{baseUrl}}"],
              "path": ["flights", "1", "seats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Tras el PATCH la llave fue invalidada: vuelve a consultar la base de datos', function () {",
                  "  pm.expect(data.source).to.eql('database');",
                  "});",
                  "",
                  "const seatId = pm.collectionVariables.get('seatId');",
                  "const updatedSeat = data.seats.find((seat) => String(seat.id) === seatId);",
                  "pm.test('El mapa de asientos ya refleja el estado held', function () {",
                  "  pm.expect(updatedSeat.status).to.eql('held');",
                  "});"
                ]
              }
            }
          ]
